#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

LABEL="com.cockpit.app"
CAL_LABEL="com.cockpit.calendar"
RUNNER_LABEL="com.cockpit.runner"
PLIST_TEMPLATE="services/cockpit.plist.template"
CAL_PLIST_TEMPLATE="services/cockpit-calendar.plist.template"
RUNNER_PLIST_TEMPLATE="services/cockpit-runner.plist.template"
PLIST_DEST="$HOME/Library/LaunchAgents/${LABEL}.plist"
CAL_PLIST_DEST="$HOME/Library/LaunchAgents/${CAL_LABEL}.plist"
RUNNER_PLIST_DEST="$HOME/Library/LaunchAgents/${RUNNER_LABEL}.plist"
PROJECT_DIR="$(pwd -P)"
DOMAIN_TARGET="gui/$(id -u)"

usage() {
  cat <<EOF
Usage: bin/service <command>

Commands:
  install             plist を生成して ~/Library/LaunchAgents/ に置き、launchd に登録する
  uninstall           launchd から外し、plist ファイルを削除する
  restart             プロセスを再起動する（build 更新後などに使用）
  status              launchd の登録状態を表示
  logs                out ログを tail -f
  errlogs             err ログを tail -f
  calendar-install    calendar-sync エージェントを launchd に登録する
  calendar-uninstall  calendar-sync エージェントを launchd から外す
  calendar-status     calendar-sync エージェントの登録状態を表示
  runner-install      runner を launchd に登録する
  runner-uninstall    runner を launchd から外す
  runner-restart      runner プロセスを再起動する
  runner-status       runner の登録状態を表示
  runner-logs         runner ログを tail -f
  runner-token-sync <owner>
                      1Password から owner 別トークンを ~/.config/cockpit/tokens/<owner> へ同期する

Label: ${LABEL} / ${CAL_LABEL} / ${RUNNER_LABEL}
Plist: ${PLIST_DEST}
EOF
}

render_plist() {
  local template="$1" label="$2"
  sed \
    -e "s|__LABEL__|${label}|g" \
    -e "s|__PROJECT_DIR__|${PROJECT_DIR}|g" \
    -e "s|__HOME__|${HOME}|g" \
    -e "s|__NODE__|$(command -v node)|g" \
    "${template}"
}

install_agent() {
  local template="$1" label="$2" dest="$3"
  [[ -f "${template}" ]] || { echo "template が見つかりません: ${template}" >&2; exit 1; }
  mkdir -p "$HOME/Library/LaunchAgents"
  render_plist "${template}" "${label}" > "${dest}"
  echo "wrote ${dest}"

  if launchctl print "${DOMAIN_TARGET}/${label}" >/dev/null 2>&1; then
    echo "既に登録済みなので一度外します"
    launchctl bootout "${DOMAIN_TARGET}/${label}" || true
  fi

  launchctl bootstrap "${DOMAIN_TARGET}" "${dest}"
}

uninstall_agent() {
  local label="$1" dest="$2"
  if launchctl print "${DOMAIN_TARGET}/${label}" >/dev/null 2>&1; then
    launchctl bootout "${DOMAIN_TARGET}/${label}"
    echo "launchd から外しました"
  else
    echo "登録されていません"
  fi
  if [[ -f "${dest}" ]]; then
    rm -f "${dest}"
    echo "removed ${dest}"
  fi
}

status_agent() {
  local label="$1"
  if launchctl print "${DOMAIN_TARGET}/${label}" >/dev/null 2>&1; then
    launchctl print "${DOMAIN_TARGET}/${label}" | grep -E "state|program|last exit|pid" | sed 's/^\s*//'
  else
    echo "not loaded"
  fi
}

cmd_install() {
  mkdir -p "$HOME/Library/Logs"
  install_agent "${PLIST_TEMPLATE}" "${LABEL}" "${PLIST_DEST}"
  echo "launchd に登録しました。 http://localhost:${PORT:-7878}"
}

cmd_restart() {
  launchctl kickstart -k "${DOMAIN_TARGET}/${LABEL}"
  echo "restarted"
}

cmd_logs() {
  local path="$HOME/Library/Logs/cockpit.out.log"
  [[ -f "$path" ]] || { echo "no log yet: $path"; exit 0; }
  tail -f "$path"
}

cmd_errlogs() {
  local path="$HOME/Library/Logs/cockpit.err.log"
  [[ -f "$path" ]] || { echo "no err log yet: $path"; exit 0; }
  tail -f "$path"
}

cmd_runner_logs() {
  local out_path="$HOME/Library/Logs/cockpit-runner.out.log"
  local err_path="$HOME/Library/Logs/cockpit-runner.err.log"
  [[ -f "$out_path" ]] || { echo "no log yet: $out_path (err log: $err_path)"; exit 0; }
  tail -f "$out_path" "$err_path"
}

# 1Password から owner 別トークンを ~/.config/cockpit/tokens/<owner> へ同期する。
# op://Private/cockpit-github-token-<owner>/password を読み、対象 owner に限定した
# fine-grained PAT を 1 ファイル 1 owner で配置する (COCKPIT_RUNNER_TOKEN_OP_REF で
# 参照先を上書き可、COCKPIT_TOKENS_DIR で配置先ディレクトリを上書き可)。
cmd_runner_token_sync() {
  local owner="${1:?owner を指定してください (例: runner-token-sync acme)}"
  local ref="${COCKPIT_RUNNER_TOKEN_OP_REF:-op://Private/cockpit-github-token-${owner}/password}"
  local dir="${COCKPIT_TOKENS_DIR:-$HOME/.config/cockpit/tokens}"
  local file="${dir}/${owner}"
  command -v op >/dev/null || { echo "op (1Password CLI) が見つかりません" >&2; exit 1; }
  mkdir -p "${dir}"
  rm -f "${file}"; install -m 600 /dev/null "${file}"
  if ! op read "${ref}" > "${file}"; then
    rm -f "${file}"; echo "op read に失敗: ${ref}" >&2; exit 1
  fi
  echo "synced ${ref} -> ${file}"
}

# 構造ガード (Issue #54): runner は weak PAT (対象リポジトリ owner 限定の
# fine-grained PAT) が無いと起動しない (fail-closed、runner/github-token.ts)。
# install / restart の前に同じ判定で preflight し、launchd 配下でのクラッシュ
# ループを未然に防ぐ。~/.config/cockpit/tokens/ 配下の owner 別トークンを全件
# 検証する (COCKPIT_TOKENS_DIR で配置先ディレクトリを上書き可)。
# 判定を runner の loadRunnerToken と揃える: 前後空白を除去して空、または内部に
# 空白 (複数行・複数トークン) があれば NG。加えて GitHub API で有効性も検証する。
# 1 つでも MISSING/INVALID/NG があれば非ゼロで返す。
check_runner_token() {
  local dir="${COCKPIT_TOKENS_DIR:-$HOME/.config/cockpit/tokens}"
  if [[ ! -d "${dir}" ]] || [[ -z "$(ls -A "${dir}" 2>/dev/null)" ]]; then
    echo "runner-token: MISSING (${dir}/<owner> に fine-grained PAT を配置してください)"
    return 1
  fi
  local failed=0
  local f tok
  for f in "${dir}"/*; do
    tok="$(<"${f}")"
    tok="${tok#"${tok%%[![:space:]]*}"}"
    tok="${tok%"${tok##*[![:space:]]}"}"
    if [[ -z "${tok}" || "${tok}" == *[[:space:]]* ]]; then
      echo "runner-token: INVALID ($(basename "${f}") — 空または複数行です)"
      failed=1
    elif GH_TOKEN="${tok}" gh api rate_limit >/dev/null 2>&1; then
      echo "runner-token: ok ($(basename "${f}"))"
    else
      echo "runner-token: NG ($(basename "${f}") — 認証失敗)"
      failed=1
    fi
  done
  [[ "${failed}" -eq 0 ]]
}

case "${1:-}" in
  install)            cmd_install ;;
  uninstall)          uninstall_agent "${LABEL}" "${PLIST_DEST}" ;;
  restart)            cmd_restart ;;
  status)             status_agent "${LABEL}" ;;
  logs)               cmd_logs ;;
  errlogs)            cmd_errlogs ;;
  calendar-install)   install_agent "${CAL_PLIST_TEMPLATE}" "${CAL_LABEL}" "${CAL_PLIST_DEST}"
                      echo "calendar-sync を launchd に登録しました" ;;
  calendar-uninstall) uninstall_agent "${CAL_LABEL}" "${CAL_PLIST_DEST}" ;;
  calendar-status)    status_agent "${CAL_LABEL}" ;;
  runner-install)     [[ -f dist/runner.cjs ]] || { echo "先に pnpm build:runner を実行してください" >&2; exit 1; }
                      check_runner_token >&2 || exit 1
                      install_agent "${RUNNER_PLIST_TEMPLATE}" "${RUNNER_LABEL}" "${RUNNER_PLIST_DEST}"
                      echo "runner を launchd に登録しました" ;;
  runner-uninstall)   uninstall_agent "${RUNNER_LABEL}" "${RUNNER_PLIST_DEST}" ;;
  runner-restart)     check_runner_token >&2 || exit 1
                      launchctl kickstart -k "${DOMAIN_TARGET}/${RUNNER_LABEL}"
                      echo "runner restarted" ;;
  runner-status)      status_agent "${RUNNER_LABEL}"
                      echo "--- health ---"
                      command -v gh >/dev/null && gh auth status >/dev/null 2>&1 && echo "gh: ok" || echo "gh: NG (gh auth login)"
                      git wt >/dev/null 2>&1 && echo "git wt: ok" || echo "git wt: NG (brew install k1LoW/tap/git-wt)"
                      check_runner_token || true
                      [[ -S "$HOME/.cache/cockpit/runner.sock" ]] && echo "socket: ok" || echo "socket: not listening" ;;
  runner-logs)        cmd_runner_logs ;;
  runner-token-sync)  cmd_runner_token_sync "$2" ;;
  ""|help|-h|--help)  usage ;;
  *) echo "unknown command: $1" >&2; usage; exit 1 ;;
esac
